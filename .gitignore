.env
*.env
.env.local
.env.*.local
secrets.py
secrets/

# ── Python ───────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── uv / 가상환경 ────────────────────────
.venv/
venv/
env/
ENV/
.uv/
uv.lock         # 팀 프로젝트면 제거할 것 (공유 시 포함 권장)

# ── 빌드·배포 ────────────────────────────
dist/
build/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
share/python-wheels/

# ── 테스트·커버리지 ──────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ──────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── 로그 ─────────────────────────────────
*.log
logs/

# ── Flask 세션 ────────────────────────────
flask_session/

# ── OS ───────────────────────────────────
.DS_Store
desktop.ini
